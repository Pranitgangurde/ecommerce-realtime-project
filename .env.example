ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=changeme_local_only

# Event generator
EVENTS_PER_SECOND=10
EVENT_GENERATOR_DURATION_SECONDS=0  # 0 = run forever